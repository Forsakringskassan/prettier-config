{
    "extends": ["@tsconfig/strictest", "@tsconfig/node22"],
    "compilerOptions": {
        "rootDir": "${configDir}/src",
        "outDir": "${configDir}/dist",

        "emitDeclarationOnly": true,
        "declaration": true,
        "types": ["node"],

        "module": "esnext",
        "moduleResolution": "bundler"
    },
    "include": ["./src/**/*.ts"]
}
